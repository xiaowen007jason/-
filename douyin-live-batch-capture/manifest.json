{
  "manifest_version": 3,
  "name": "小文抖音直播间批量截图",
  "version": "0.4.0",
  "description": "小文出品：在当前已登录的浏览器中收集品牌直播间，并依次截取高清直播主画面。",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "downloads",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://www.douyin.com/*",
    "https://live.douyin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "小文抖音直播间批量截图",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.douyin.com/*",
        "https://live.douyin.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
